# =====================================================================
# .env.example — 環境変数のテンプレート
# =====================================================================
# 使い方:
#   1. このファイルを ".env" にコピー (cp .env.example .env)
#   2. 値を実環境に合わせて書き換え
#   3. .env は .gitignore でGit管理外（コミットしないこと）
#
# 配置場所:
#   - ローカル開発: task-board/.env (リポジトリ内)
#   - EC2 上    : /home/ec2-user/.env (start.sh が source する)
# =====================================================================

# --- Backend (Spring Boot) → DB 接続 ---
# 本番(EC2+RDS): RDS endpoint と認証情報を入れる
# ローカル開発: 設定不要（application.yml の default が localhost:5432 を指す）
DATABASE_URL=jdbc:postgresql://YOUR_RDS_ENDPOINT:5432/taskboard
DATABASE_USERNAME=taskboard
DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# --- Backend → CORS 許可オリジン ---
# カンマ区切りで複数指定可能。EC2 デプロイでは EIP を含む URL を必ず追加。
# 例（ローカル + EC2 両方許可）:
#   CORS_ALLOWED_ORIGINS=http://localhost:5173,http://YOUR_EC2_EIP:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://YOUR_EC2_EIP:5173

# --- docker-compose ローカル開発用（任意） ---
# default は taskboard のため、特殊な値を使う場合のみ設定
POSTGRES_DB=taskboard
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=taskboard
